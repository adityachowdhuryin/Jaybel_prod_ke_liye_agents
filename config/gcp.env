# Gitignored — GCP + Vertex Agent Engine for local UI (source via scripts or start-all.sh).
# Defaults match scripts/deploy-agent-engine.ps1; change ORCHESTRATOR_AGENT_ENGINE_RESOURCE if your engine id differs (Console → Copy identity).

export GOOGLE_CLOUD_PROJECT=gls-training-486405
export GOOGLE_CLOUD_LOCATION=us-central1

export VERTEX_MODEL_ID=gemini-2.5-flash
export AGENT_ENGINE_SERVICE_ACCOUNT=910005263485-compute@developer.gserviceaccount.com

# Vertex Agent Engine (optional). For local UI + BigQuery cost agent on :8001, keep LOCAL_CHAT on.
# Unset ORCHESTRATOR_LOCAL_CHAT and fix ADC/IAM on the engine if you want every chat via Agent Engine.
# Same engines as scripts/deploy-agent-engine.sh (project id form; equivalent to numeric project in Console).
export ORCHESTRATOR_AGENT_ENGINE_RESOURCE=projects/gls-training-486405/locations/us-central1/reasoningEngines/7920943888905273344
export COST_AGENT_ENGINE_RESOURCE=projects/gls-training-486405/locations/us-central1/reasoningEngines/3600096288210681856
export AGENT_ENGINE_EVAL_GCS_DEST=gs://gls-training-486405-adk-staging/agent-engine-evals
export ORCHESTRATOR_LOCAL_CHAT=0
export ENABLE_VERTEX_ROUTING=1

# Cost agent → BigQuery billing export (resource-level table in gls-training-486405)
export BQ_BILLING_PROJECT=gls-training-486405
export BQ_BILLING_DATASET=gcp_billing_data
export BQ_BILLING_TABLE=jaybel_prod_billing_view
export BILLING_BQ_SCHEMA_MODE=clean_view
# Default GCP project id for billing filters when users say "our project" (router + guardrail).
export BILLING_DEFAULT_PROJECT_ID=jaybel-prod
# Workflow / runtime view (dual-source routing with billing view). Deploy script sets these on the cost engine.
export BQ_WORKFLOW_PROJECT=gls-training-486405
export BQ_WORKFLOW_DATASET=gcp_billing_data
export BQ_WORKFLOW_TABLE=jaybel_prod_workflow_view
# Legacy: only used as fallback table name if BQ_WORKFLOW_TABLE is unset.
# export BQ_COST_EVENTS_TABLE=cost_events
# Prefer BigQuery when configured; falls back to Postgres sample data if BQ fails (auto).
export COST_DATA_SOURCE=bigquery
export BILLING_CONTEXT_ROUTER_ENABLED=1
export BILLING_LLM_MAX_LOOKBACK_DAYS=0
export BILLING_DEFAULT_TILL_NOW_SCOPE=full_history
export BILLING_FULL_HISTORY_START_DATE=2026-01-01
