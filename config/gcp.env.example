# Copy to config/gcp.env (gitignored) — do not commit secrets.
# Vertex AI Agent Engine + laptop deploy (gcloud auth as your user).

export GOOGLE_CLOUD_PROJECT=gls-training-486405
export GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model for ADK / Agent Engine + billing LLM SQL (Vertex default chain)
export VERTEX_MODEL_ID=gemini-2.5-flash

# Runtime service account (Agent Engine identity)
export AGENT_ENGINE_SERVICE_ACCOUNT=910005263485-compute@developer.gserviceaccount.com

# Cost agent: hybrid DB — store DSN in Secret Manager; reference name only here
# export DATABASE_URL_SECRET_NAME=database-url

# Cost agent: live BigQuery billing export (Agent Engine path)
export BQ_BILLING_PROJECT=gls-training-486405
export BQ_BILLING_DATASET=gcp_billing_data
export BQ_BILLING_TABLE=clean_billing_view
# raw_export | clean_view
export BILLING_BQ_SCHEMA_MODE=clean_view
# bigquery is recommended for Agent Engine-only operation
export COST_DATA_SOURCE=bigquery

# --- Billing agent: LLM-generated BigQuery SQL ---
# BigQuery cost questions use guarded Vertex/Google AI SQL. Set BILLING_AGENT_LLM_SQL=0 for parameterized queries only (no LLM).
# SQL synthesis uses structured JSON (response_schema) — no markdown extraction from model text.
export BILLING_AGENT_LLM_SQL=1
# Cost context router (Gemini JSON) for dates/filters/rewrite before SQL generation.
export BILLING_CONTEXT_ROUTER_ENABLED=1
# Optional override; defaults to VERTEX_MODEL_ID / gemini-2.5-flash.
# export BILLING_CONTEXT_ROUTER_MODEL=gemini-2.5-flash
# auto | vertex | google_ai — auto tries Vertex (ADC) then Google AI on 403.
export BILLING_LLM_PROVIDER=auto
# Optional: Google AI Studio API key if your user lacks aiplatform.endpoints.predict on Vertex.
# export GOOGLE_AI_API_KEY=
# export BILLING_LLM_GOOGLE_AI_MODEL=gemini-2.5-flash
# Hard cap for estimated/actual bytes processed on LLM queries (default 1 GB).
export BILLING_LLM_MAX_BYTES_BILLED=1000000000
# Default interpretation for "till now"/"until now" when no explicit month/range is given:
# - full_history (recommended for discovery/list questions)
# - month_to_date
# Also applies to variants like "till date", "to date", and "so far" in fallback mode.
export BILLING_DEFAULT_TILL_NOW_SCOPE=full_history
# Earliest date for full-history-to-date default (YYYY-MM-DD). Keep this realistic for your billing table.
export BILLING_FULL_HISTORY_START_DATE=2026-01-01
# Max calendar span for LLM path when day-based clamping is enabled.
# Set to 0 to disable day-based clamping entirely (recommended when relying on byte caps).
export BILLING_LLM_MAX_LOOKBACK_DAYS=30
# Keep explicit full calendar windows (e.g. March 2026 = 31 days) even when max lookback is 30.
export BILLING_LLM_ALLOW_EXPLICIT_CALENDAR_WINDOW=1
# Set to 1 to allow wider natural-language windows (still subject to BILLING_LLM_MAX_BYTES_BILLED).
export BILLING_LLM_ALLOW_LONG_RANGE=0
# Optional override for billing SQL only (defaults to VERTEX_MODEL_ID then gemini-2.5-flash).
# export BILLING_LLM_MODEL=gemini-1.5-flash
# SA key path for cost agent + local tools (or rely on gcloud ADC)
# export GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# After cost Agent Engine is deployed: full URL to Agent Card JSON for the orchestrator
# export COST_AGENT_A2A_CARD_URL=https://.../.well-known/agent.json

# Route the Next.js UI through Vertex (every /chat/stream calls Agent Engine stream_query):
# Set the deployed pa_orchestrator_agent resource name (Console → Copy identity), e.g.
#   projects/gls-training-486405/locations/us-central1/reasoningEngines/8296018091465244672
# export ORCHESTRATOR_AGENT_ENGINE_RESOURCE=projects/PROJECT/locations/REGION/reasoningEngines/NUMERIC_ID
# Cost specialist engine resource (used by observability seeding helpers):
# export COST_AGENT_ENGINE_RESOURCE=projects/PROJECT/locations/REGION/reasoningEngines/NUMERIC_ID
# GCS destination prefix for Vertex evaluation artifacts:
# export AGENT_ENGINE_EVAL_GCS_DEST=gs://YOUR_BUCKET/agent-engine-evals
#
# Agent Engine-only mode: keep ORCHESTRATOR_LOCAL_CHAT unset (or 0).
# If ADC/IAM is missing, /chat/stream will return a clear 503.
# Or paste the full :query HTTPS URL from the console:
# export ORCHESTRATOR_AGENT_ENGINE_QUERY_URL=https://REGION-aiplatform.googleapis.com/v1/projects/PROJECT/locations/REGION/reasoningEngines/ID:query
# Then run agents/orchestrator with ADC: gcloud auth application-default login

# --- Orchestrator: Postgres chat memory + JWT ---
# Same DATABASE_URL as cost agent / docker compose postgres (host stack often :5433).
# export DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5435/postgres
# Dev: skip JWT (maps all requests to dev-user / tenant default).
# export ORCHESTRATOR_AUTH_DISABLED=1
# Prod: require Authorization: Bearer <JWT>; validate with JWKS or HS256 secret.
# export ORCHESTRATOR_AUTH_DISABLED=0
# export JWT_ALG=RS256
# export JWT_JWKS_URL=https://your-idp/.well-known/jwks.json
# Optional: export JWT_AUDIENCE=...   export JWT_ISSUER=...
# HS256 local tests: export JWT_ALG=HS256  export JWT_HS256_SECRET=...
# Single-tenant placeholder for row scoping:
# export DEFAULT_TENANT_ID=default
# Auth-disabled dev identity override:
# export ORCHESTRATOR_DEV_USER_ID=dev-user
#
# Session summary compression (Vertex Gemini): defaults to VERTEX_MODEL_ID / gemini-2.5-flash
# export SESSION_SUMMARY_VERTEX_MODEL=gemini-2.5-flash
# Orchestrator LLM router (Gemini JSON intent + Gemini task refinement).
export ENABLE_VERTEX_ROUTING=1
#
# Chat retention (optional cron POST /internal/chat/retention with X-API-Key)
# export CHAT_RETENTION_DAYS=90
# export RETENTION_API_KEY=...

# Deploy (bash): source this file, then from repo root:
#   adk deploy agent_engine --project=$GOOGLE_CLOUD_PROJECT --region=$GOOGLE_CLOUD_LOCATION \
#     --trace_to_cloud --otel_to_cloud vertex_agents/cost_metrics_agent
#   adk deploy agent_engine ... vertex_agents/pa_orchestrator_agent
