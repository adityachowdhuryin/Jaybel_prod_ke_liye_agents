# Copy to config/gcp.env (gitignored) — do not commit secrets.
# Vertex AI Agent Engine + laptop deploy (gcloud auth as your user).

export GOOGLE_CLOUD_PROJECT=gls-training-486405
export GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model for ADK agents
export VERTEX_MODEL_ID=gemini-2.5-flash

# Runtime service account (Agent Engine identity)
export AGENT_ENGINE_SERVICE_ACCOUNT=910005263485-compute@developer.gserviceaccount.com

# Cost agent: hybrid DB — store DSN in Secret Manager; reference name only here
# export DATABASE_URL_SECRET_NAME=database-url

# Optional ingestion pipeline (BigQuery Billing Export -> PostgreSQL cloud_costs)
# export BILLING_BQ_PROJECT=gls-training-486405
# export BILLING_BQ_DATASET=your_billing_export_dataset
# export BILLING_BQ_TABLE=gcp_billing_export_v1_xxxxx

# After cost Agent Engine is deployed: full URL to Agent Card JSON for the orchestrator
# export COST_AGENT_A2A_CARD_URL=https://.../.well-known/agent.json

# Route the Next.js UI through Vertex (every /chat/stream calls Agent Engine stream_query):
# Set the deployed pa_orchestrator_agent resource name (Console → Copy identity), e.g.
#   projects/gls-training-486405/locations/us-central1/reasoningEngines/8296018091465244672
# export ORCHESTRATOR_AGENT_ENGINE_RESOURCE=projects/PROJECT/locations/REGION/reasoningEngines/NUMERIC_ID
# Or paste the full :query HTTPS URL from the console:
# export ORCHESTRATOR_AGENT_ENGINE_QUERY_URL=https://REGION-aiplatform.googleapis.com/v1/projects/PROJECT/locations/REGION/reasoningEngines/ID:query
# Then run agents/orchestrator with ADC: gcloud auth application-default login

# Legacy orchestrator proactive route (/proactive/morning-brief)
# export PROACTIVE_API_KEY=replace-with-strong-random-value

# Deploy (bash): source this file, then from repo root:
#   adk deploy agent_engine --project=$GOOGLE_CLOUD_PROJECT --region=$GOOGLE_CLOUD_LOCATION \
#     --trace_to_cloud --otel_to_cloud vertex_agents/cost_metrics_agent
#   adk deploy agent_engine ... vertex_agents/pa_orchestrator_agent
