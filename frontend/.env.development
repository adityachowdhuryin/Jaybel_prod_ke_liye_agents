# Defaults when running `npm run dev` without scripts/start-all.sh.
# scripts/start-all.sh overwrites .env.development.local (higher priority) with proxy + optional Speech paths.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:8000
NEXT_PUBLIC_USE_CHAT_PROXY=1
ORCHESTRATOR_SERVER_URL=http://127.0.0.1:8000
