# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (ignore by default; tracked templates below)
.env*.local
!.env.development.local
!.env.local

# GCP keys under .secrets/ — never commit key JSON; README + .gitkeep are tracked
.secrets/**
!.secrets/
!.secrets/README.md
!.secrets/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
