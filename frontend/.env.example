# Local dev: run `./scripts/start-all.sh` from repo root — it writes `.env.development.local`
# (proxy + optional Speech) so you do not need to copy this file by hand.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:8000
NEXT_PUBLIC_USE_CHAT_PROXY=1
ORCHESTRATOR_SERVER_URL=http://127.0.0.1:8000
# ORCHESTRATOR_SERVER_BEARER=

# Google Cloud Speech-to-Text v2 (/api/transcribe). Never use NEXT_PUBLIC_.
# Local dev: path to the service account JSON (see repo docs / setup script).
GOOGLE_CLOUD_PROJECT=gls-training-486405
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/frontend/.secrets/speech-sa.json

# Chirp 3: use multi-region us or eu (not global). The API client must call the
# matching host (e.g. us -> us-speech.googleapis.com); the app sets this automatically.
# GCP_SPEECH_LOCATION=us
# GCP_SPEECH_MODEL=chirp_3
# GCP_SPEECH_LANGUAGE_CODE=en-US
# Serverless alternative: GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
