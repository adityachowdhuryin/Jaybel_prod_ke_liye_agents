# Copy to .env in this folder for deploy (gitignored). Never commit real credentials.
GOOGLE_CLOUD_PROJECT=gls-training-486405
GOOGLE_CLOUD_LOCATION=us-central1

# BigQuery is the primary backend in current deployment.
COST_DATA_SOURCE=bigquery
BQ_BILLING_PROJECT=gls-training-486405
BQ_BILLING_DATASET=gcp_billing_data
BQ_BILLING_TABLE=clean_billing_view
BILLING_BQ_SCHEMA_MODE=clean_view
BILLING_AGENT_LLM_SQL=1
BILLING_CONTEXT_ROUTER_ENABLED=1
BILLING_LLM_PROVIDER=auto
BILLING_LLM_MAX_BYTES_BILLED=1000000000
BILLING_LLM_MAX_LOOKBACK_DAYS=0

# Till-now defaults when user does not provide an explicit window.
BILLING_DEFAULT_TILL_NOW_SCOPE=full_history
BILLING_FULL_HISTORY_START_DATE=2026-01-01

# Optional Postgres fallback path for hybrid deployments.
# Vertex AI Agent Engine cannot reach 127.0.0.1 on your laptop.
# Expose local Postgres via tunnel and set DATABASE_URL only if needed.
# DATABASE_URL=postgresql://USER:PASSWORD@TUNNEL_HOST:TUNNEL_PORT/postgres
