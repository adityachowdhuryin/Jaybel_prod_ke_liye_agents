# Copy to .env in this folder for deploy (gitignored). Never commit real credentials.
GOOGLE_CLOUD_PROJECT=gls-training-486405
GOOGLE_CLOUD_LOCATION=us-central1

# Self-hosted / Docker Postgres (not Cloud SQL): fine for local ADK runs.
# Vertex AI Agent Engine runs in GCP — it cannot use 127.0.0.1 on your PC.
# Expose local Postgres with a TCP tunnel (ngrok or cloudflared) and set HOST:PORT to
# the tunnel endpoint. See docs/PHASE2-RUNBOOK.md and infra/tunnel/*.example.yml
DATABASE_URL=postgresql://USER:PASSWORD@TUNNEL_HOST:TUNNEL_PORT/postgres

# postgres = Postgres only (good with local DB + tunnel). auto tries BigQuery first if configured.
COST_DATA_SOURCE=postgres

# BigQuery Billing Export source (set these to enable direct billing reads)
# BQ_BILLING_PROJECT=gls-training-486405
# BQ_BILLING_DATASET=your_billing_export_dataset
# BQ_BILLING_TABLE=gcp_billing_export_v1_xxxxx
